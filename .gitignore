# macOS
.DS_Store

# Personal data — never commit, even on a private fork unless you edit this file
resumes/*
!resumes/README.md

# Outreach contact logs — local only, contains names + LinkedIn URLs
outreach/*.md
!outreach/.gitkeep

# Application folders — local only if you create them
applications/

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# Python (in case you add scripts)
__pycache__/
*.pyc
.venv/
venv/

# Claude Code local settings
.claude/settings.local.json
